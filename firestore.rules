rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      // Bootstrapped admin using the known email from runtime metadata
      return isEmailVerified() && request.auth.token.email == 'teaminfinitium.arsd@gmail.com';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- About Rules ---
    match /about/{docId} {
      function isValidAbout(data) {
        return data.keys().hasAll(['hero', 'objectives', 'impacts', 'departments']) 
          && data.keys().size() == 4
          && data.hero is map
          && data.hero.title is string && data.hero.title.size() <= 200
          && data.hero.paragraph is string && data.hero.paragraph.size() <= 4000
          && data.hero.image is string && data.hero.image.size() <= 1000000
          && data.objectives is list
          && data.impacts is list
          && data.departments is list;
      }

      allow read: if true;
      allow create: if isAdmin() && isValidAbout(incoming());
      allow update: if isAdmin() && isValidAbout(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['hero', 'objectives', 'impacts', 'departments'])
      );
      allow delete: if isAdmin();
    }

    // --- Gallery Rules ---
    match /gallery/{itemId} {
      function isValidGalleryItem(data) {
        return data.keys().hasAll(['src', 'title', 'category', 'description'])
          && data.keys().size() >= 4 && data.keys().size() <= 9
          && data.src is string && data.src.size() <= 1048576
          && data.title is string && data.title.size() <= 200
          && data.category is string && data.category.size() <= 50
          && data.description is string && data.description.size() <= 1000
          && (!data.keys().hasAll(['createdAt']) || data.createdAt is timestamp)
          && (!data.keys().hasAll(['eventId']) || data.eventId is string)
          && (!data.keys().hasAll(['eventDate']) || data.eventDate is string);
      }

      allow read: if true;
      allow create: if isAdmin() && isValidId(itemId) && isValidGalleryItem(incoming()) && incoming().createdAt == request.time;
      allow update: if isAdmin() && isValidId(itemId) && isValidGalleryItem(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['src', 'title', 'category', 'description', 'createdAt', 'eventId', 'eventDate'])
      );
      allow delete: if isAdmin();
    }

    // --- Achievements Rules ---
    match /achievements/{id} {
      function isValidAchievement(data) {
        return data.keys().hasAll(['title', 'description', 'date'])
          && data.keys().size() >= 3 && data.keys().size() <= 4
          && data.title is string && data.title.size() <= 200
          && data.description is string && data.description.size() <= 2000
          && data.date is string && data.date.size() <= 50
          && (!data.keys().hasAll(['createdAt']) || data.createdAt is timestamp);
      }

      allow read: if true;
      allow create: if isAdmin() && isValidId(id) && isValidAchievement(incoming()) && incoming().createdAt == request.time;
      allow update: if isAdmin() && isValidId(id) && isValidAchievement(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'date', 'createdAt'])
      );
      allow delete: if isAdmin();
    }

    // --- Team Rules ---
    match /members/{memberId} {
      function isValidMember(data) {
        return data.keys().hasAll(['name', 'role', 'tenure', 'image'])
          && data.keys().size() >= 4 && data.keys().size() <= 6
          && data.name is string && data.name.size() <= 100
          && data.role is string && data.role.size() <= 100
          && data.tenure is string && data.tenure.matches('^[0-9]{4}-[0-9]{2}$')
          && data.image is string && data.image.size() <= 1000000
          && (!data.keys().hasAll(['linkedin']) || data.linkedin is string)
          && (!data.keys().hasAll(['createdAt']) || data.createdAt is timestamp);
      }

      allow read: if true;
      allow create: if isAdmin() && isValidId(memberId) && isValidMember(incoming()) && incoming().createdAt == request.time;
      allow update: if isAdmin() && isValidId(memberId) && isValidMember(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'role', 'tenure', 'image', 'linkedin', 'createdAt'])
      );
      allow delete: if isAdmin();
    }

    // --- Events Rules ---
    match /events/{eventId} {
      function isValidEvent(data) {
        return data.keys().hasAll(['title', 'description', 'date', 'type'])
          && data.keys().size() >= 4 && data.keys().size() <= 17
          && data.title is string && data.title.size() <= 200
          && data.description is string && data.description.size() <= 2000
          && data.date is string
          && data.type is string
          && (!data.keys().hasAll(['isInterCollege']) || data.isInterCollege is bool)
          && (!data.keys().hasAll(['sheetId']) || (data.sheetId is string && data.sheetId.size() <= 100))
          && (!data.keys().hasAll(['subtitle']) || data.subtitle is string)
          && (!data.keys().hasAll(['location']) || data.location is string)
          && (!data.keys().hasAll(['image']) || (data.image is string && data.image.size() <= 1048576))
          && (!data.keys().hasAll(['status']) || data.status is string)
          && (!data.keys().hasAll(['stats']) || data.stats is map)
          && (!data.keys().hasAll(['startTime']) || data.startTime is string)
          && (!data.keys().hasAll(['createdAt']) || data.createdAt is timestamp);
      }

      allow read: if true;
      allow create: if isAdmin() && isValidId(eventId) && isValidEvent(incoming()) && incoming().createdAt == request.time;
      allow update: if isAdmin() && isValidId(eventId) && isValidEvent(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['title', 'subtitle', 'description', 'date', 'location', 'image', 'type', 'status', 'sheetId', 'stats', 'createdAt', 'isInterCollege', 'startTime'])
      );
      allow delete: if isAdmin();

      match /photos/{photoId} {
        function isValidPhoto(data) {
          return data.keys().hasAll(['src', 'createdAt'])
            && data.keys().size() == 2
            && data.src is string && data.src.size() <= 1048000
            && data.createdAt is timestamp;
        }

        allow read: if true;
        allow create: if isAdmin() && isValidId(photoId) && isValidPhoto(incoming());
        allow delete: if isAdmin();
      }

      match /registrations/{regId} {
        function isValidRegistration(data) {
          return data.keys().hasAll(['studentName', 'rollNo', 'email', 'ticketId', 'eventId', 'createdAt'])
            && data.keys().size() >= 6 && data.keys().size() <= 20
            && data.studentName is string && data.studentName.size() <= 200
            && data.rollNo is string && data.rollNo.size() <= 100
            && data.email is string && data.email.size() <= 200
            && data.ticketId is string && data.ticketId.size() <= 50
            && data.eventId == eventId
            && data.createdAt is timestamp
            && (!data.keys().hasAll(['phoneNo']) || data.phoneNo is string)
            && (!data.keys().hasAll(['course']) || data.course is string)
            && (!data.keys().hasAll(['otherCourse']) || data.otherCourse is string)
            && (!data.keys().hasAll(['year']) || data.year is string)
            && (!data.keys().hasAll(['collegeName']) || data.collegeName is string)
            && (!data.keys().hasAll(['eventTitle']) || data.eventTitle is string)
            && (!data.keys().hasAll(['isPartOfSociety']) || data.isPartOfSociety is string)
            && (!data.keys().hasAll(['societyDepartment']) || data.societyDepartment is string)
            && (!data.keys().hasAll(['availability']) || data.availability is string)
            && (!data.keys().hasAll(['sheetId']) || (data.sheetId is string || data.sheetId == null))
            && (!data.keys().hasAll(['attended']) || data.attended is bool);
        }

        allow read: if isAdmin();
        allow create: if isValidId(regId) && isValidRegistration(incoming()) && incoming().createdAt == request.time && (!incoming().keys().hasAll(['attended']) || incoming().attended == false);
        allow update: if isAdmin() && (
          incoming().diff(existing()).affectedKeys().hasOnly(['attended'])
        );
        allow delete: if isAdmin();
      }
    }

    // --- Contact Messages Rules ---
    match /contact_messages/{messageId} {
      function isValidMessage(data) {
        return data.keys().hasAll(['name', 'email', 'message', 'status', 'timestamp'])
          && data.keys().size() == 5
          && data.name is string && data.name.size() <= 100
          && data.email is string && data.email.size() <= 200
          && data.message is string && data.message.size() <= 5000
          && data.status in ['new', 'read', 'replied']
          && data.timestamp is timestamp;
      }

      allow read: if isAdmin();
      allow create: if isValidMessage(incoming()) && incoming().timestamp == request.time && incoming().status == 'new';
      allow update: if isAdmin() && isValidMessage(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['status'])
      );
      allow delete: if isAdmin();
    }

    // --- Temp JSONs Rules ---
    match /temp_jsons/{tempId} {
      allow read, write: if true;
    }
  }
}
