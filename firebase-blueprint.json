{
  "entities": {
    "AboutContent": {
      "title": "About Content",
      "description": "Information for the internal About page",
      "type": "object",
      "properties": {
        "hero": {
          "type": "object",
          "properties": {
            "title": { "type": "string" },
            "subtitle": { "type": "string" },
            "image": { "type": "string" }
          },
          "required": ["title", "subtitle", "image"]
        },
        "objectives": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" },
              "text": { "type": "string" }
            },
            "required": ["id", "title", "text"]
          }
        },
        "impacts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" },
              "text": { "type": "string" }
            },
            "required": ["id", "title", "text"]
          }
        },
        "departments": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" },
              "aim": { "type": "string" },
              "tasks": { "type": "array", "items": { "type": "string" } }
            },
            "required": ["id", "title", "aim", "tasks"]
          }
        }
      },
      "required": ["hero", "objectives", "impacts", "departments"]
    },
    "GalleryItem": {
      "title": "Gallery Item",
      "description": "A single image/item in the society gallery",
      "type": "object",
      "properties": {
        "src": { "type": "string", "description": "Image URL" },
        "title": { "type": "string" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["src", "title", "category", "description"]
    },
    "Achievement": {
      "title": "Achievement",
      "description": "An award or accomplishment for the hall of fame",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "date": { "type": "string", "description": "Display date e.g. Oct 2025" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "description", "date"]
    },
    "Member": {
      "title": "Member",
      "description": "A core team member of the society",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "role": { "type": "string" },
        "tenure": { "type": "string", "description": "e.g. 2024-25" },
        "image": { "type": "string", "description": "Avatar URL" },
        "linkedin": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "role", "tenure", "image"]
    },
    "Event": {
      "title": "Event",
      "description": "A society event with a linked Google Sheet",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "description": { "type": "string" },
        "date": { "type": "string" },
        "location": { "type": "string" },
        "image": { "type": "string" },
        "type": { "type": "string", "enum": ["Seminar", "Fest", "Workshop"] },
        "status": { "type": "string", "enum": ["Upcoming", "Ongoing", "Past"] },
        "isInterCollege": { "type": "boolean", "description": "Whether students from other colleges can attend" },
        "sheetId": { "type": "string", "description": "The ID of the Google Sheet for registrations" },
        "startTime": { "type": "string", "description": "Display time e.g. 10:00 AM" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "description", "date", "type", "sheetId"]
    },
    "ContactMessage": {
      "title": "Contact Message",
      "description": "A message sent via the contact form",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["new", "read", "replied"] },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "message", "status", "timestamp"]
    },
    "EventPhoto": {
      "title": "Event Photo",
      "description": "An image belongs to a specific event",
      "type": "object",
      "properties": {
        "src": { "type": "string", "description": "Image URL" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["src", "createdAt"]
    },
    "EventRegistration": {
      "title": "Event Registration",
      "description": "A student registration for an event",
      "type": "object",
      "properties": {
        "studentName": { "type": "string" },
        "rollNo": { "type": "string" },
        "email": { "type": "string" },
        "phoneNo": { "type": "string" },
        "course": { "type": "string" },
        "year": { "type": "string" },
        "collegeName": { "type": "string" },
        "eventId": { "type": "string" },
        "eventTitle": { "type": "string" },
        "ticketId": { "type": "string" },
        "sheetId": { "type": "string" },
        "attended": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["studentName", "rollNo", "email", "ticketId", "eventId", "createdAt"]
    }
  },
  "firestore": {
    "/about": {
      "schema": "AboutContent",
      "description": "Contains metadata and content for the about page"
    },
    "/gallery": {
      "schema": "GalleryItem",
      "description": "Collection of gallery items"
    },
    "/achievements": {
      "schema": "Achievement",
      "description": "Collection of achievements/hall of fame entries"
    },
    "/members": {
      "schema": "Member",
      "description": "Collection of core team members"
    },
    "/events": {
      "schema": "Event",
      "description": "Collection of society events"
    },
    "/events/{eventId}/photos": {
      "schema": "EventPhoto",
      "description": "Photos related to a specific event"
    },
    "/events/{eventId}/registrations": {
      "schema": "EventRegistration",
      "description": "Registrations for a specific event"
    },
    "/contact_messages": {
      "schema": "ContactMessage",
      "description": "Collection of messages from the contact form"
    }
  }
}
